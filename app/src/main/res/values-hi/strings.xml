<?xml version="1.0" encoding="utf-8"?>
<!--
  Hindi (hi) localization scaffold for ScanForge — Phase 8.
  Covers the high-traffic surfaces (navigation, onboarding, permissions, home, primary settings +
  privacy). Strings not listed here fall back to the default English resources automatically, so the
  app is fully usable in Hindi locale while the remaining strings are translated incrementally.
  Translations are a first pass and should get a native-speaker review before a Hindi launch.
-->
<resources>
    <!-- Brand name is kept transliterated/untranslated by design. -->
    <string name="app_name">ScanForge</string>
    <string name="home_title">ScanForge</string>

