    <!-- Home / empty state -->
    <string name="home_empty_title">अभी कोई दस्तावेज़ नहीं</string>
    <string name="home_empty_description">एक स्पष्ट, खोजने योग्य PDF बनाने के लिए अपना पहला पेज स्कैन करें।</string>
    <string name="home_scan_action">दस्तावेज़ स्कैन करें</string>
